---
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import KeyFeatures from '../components/KeyFeatures.astro';
import About from '../components/About.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import Content from '../components/Content.astro';
import Footer from '../components/Footer.astro';
import ScrollToBottom from '../components/ScrollToBottom.astro';

// Content data extracted from content/home.md
const heroData = {
	name: 'MUHAMMAD MINHAJ NADEEM',
	headline: 'Senior Mobile Engineer | Flutter & Android Specialist',
	subheadline: 'I help founders and businesses turn ideas into scalable, high-performance mobile products built with clean architecture and long-term vision.',
	ctaText: 'View My Work',
	ctaLink: '/portfolio'
};

const aboutContent = `I'm a Senior Mobile Engineer specializing in Android and Flutter, with over 8 years of experience building scalable, production-ready mobile applications.

My journey began with native Android development using Java, where I built a strong foundation in architecture, performance, and maintainable code. As the ecosystem evolved, I transitioned into Kotlin, MVVM, Clean Architecture, and modern Android development practices. Over time, I expanded into cross-platform development with Flutter, enabling businesses to move faster without compromising quality.

I've worked with startups, international remote teams, and product-based companies across Dubai and Germany — collaborating directly with founders and leadership to make key technical decisions. From e-commerce and marketplaces to communication platforms and health applications, I've built products from scratch, scaled existing systems, and improved long-term stability.

Beyond coding, I focus on product thinking — aligning technology with business goals. My approach emphasizes clean architecture, scalability, and performance to ensure apps are built not just for launch, but for growth.

I believe great software is not just written — it's engineered with vision.`;

const keyFeatures = [
	{
		title: 'Native Android Development (Java/Kotlin)',
		description: 'Building scalable, high-performance apps',
		icon: 'mobile'
	},
	{
		title: 'Cross-Platform App Development (Flutter)',
		description: 'Faster deployment across multiple platforms',
		icon: 'mobile'
	},
	{
		title: 'MVPs, Feature Additions & App Maintenance',
		description: 'Helping businesses launch & grow',
		icon: 'mobile'
	},
	{
		title: 'Android TV Apps',
		description: 'Developing interactive media experiences',
		icon: 'mobile'
	},
	{
		title: 'Technical Consulting',
		description: 'Expert guidance on architecture, scalability, and best practices for mobile development projects.',
		icon: 'consulting'
	}
];

const leadMagnetData = {
	title: 'Download My Resume',
	subtitle: 'Get a comprehensive overview of my experience, skills, and achievements. Perfect for potential clients and collaborators.',
	ctaText: 'Download Resume',
	ctaLink: 'https://drive.google.com/file/d/13kuo438vH6Zi0jwxEuT5Eseb9pXTYeva/view?usp=drive_link'
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Muhammad Minhaj Nadeem - Senior Mobile Engineer | Flutter & Android Specialist. I help founders and businesses turn ideas into scalable, high-performance mobile products." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/jpeg" href="/favicon.jpg" />
		<meta name="generator" content={Astro.generator} />
		<title>Muhammad Minhaj Nadeem - Senior Mobile Engineer</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
		<style is:global>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			:root {
				/* Color Palette */
				--color-teal: #2f9983;
				--color-navy: #1b3956;
				--color-white: #f7f0f0;
				--color-lavender: #A68FC8;
				
				/* Legacy variables for compatibility */
				--color-primary: #1b3956;
				--color-accent: #2f9983;
				--color-text: #1b3956;
				--color-text-light: #6b7280;
				--color-bg: #f7f0f0;
				--color-bg-light: #f7f0f0;
				
				/* Typography */
				--font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				
				/* Spacing */
				--spacing-xs: 0.5rem;
				--spacing-sm: 1rem;
				--spacing-md: 2rem;
				--spacing-lg: 4rem;
				--spacing-xl: 6rem;
				
				/* Border Radius */
				--radius-sm: 0.375rem;
				--radius-md: 0.5rem;
				--radius-lg: 0.75rem;
				
				/* Shadows */
				--shadow-sm: 0 1px 2px rgba(27, 57, 86, 0.05);
				--shadow-md: 0 4px 6px rgba(27, 57, 86, 0.1);
				--shadow-lg: 0 10px 25px rgba(27, 57, 86, 0.15);
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-family);
				color: var(--color-text);
				background: var(--color-bg);
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			a {
				color: inherit;
			}

			img {
				max-width: 100%;
				height: auto;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<Hero 
				name={heroData.name}
				headline={heroData.headline}
				subheadline={heroData.subheadline}
				ctaText={heroData.ctaText}
				ctaLink={heroData.ctaLink}
			/>
			<SocialProof />
			<KeyFeatures features={keyFeatures} />
			<About content={aboutContent} />
			<LeadMagnet 
				title={leadMagnetData.title}
				subtitle={leadMagnetData.subtitle}
				ctaText={leadMagnetData.ctaText}
				ctaLink={leadMagnetData.ctaLink}
			/>
			<Content />
		</main>
		<Footer />
		<ScrollToBottom />
	</body>
</html>
