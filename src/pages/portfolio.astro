---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToBottom from '../components/ScrollToBottom.astro';
import FloatingFollowBar from '../components/FloatingFollowBar.astro';
import SkillsPills from '../components/portfolio/SkillsPills.astro';
import PortfolioGridWithFilter from '../components/portfolio/PortfolioGridWithFilter.astro';
import PortfolioCTA from '../components/portfolio/PortfolioCTA.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portfolio - Muhammad Minhaj Nadeem - Native Android & Flutter mobile applications I've built and shipped." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/jpeg" href="/favicon.jpg" />
		<meta name="generator" content={Astro.generator} />
		<title>Portfolio - Muhammad Minhaj Nadeem</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
		<style is:global>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			:root {
				--color-teal: #2f9983;
				--color-navy: #1b3956;
				--color-white: #f7f0f0;
				--color-lavender: #A68FC8;
				--color-primary: #1b3956;
				--color-accent: #2f9983;
				--color-text: #1b3956;
				--color-text-light: #6b7280;
				--color-bg: #f7f0f0;
				--color-bg-light: #f7f0f0;
				--font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				--spacing-xs: 0.5rem;
				--spacing-sm: 1rem;
				--spacing-md: 2rem;
				--spacing-lg: 4rem;
				--spacing-xl: 6rem;
				--radius-sm: 0.375rem;
				--radius-md: 0.5rem;
				--radius-lg: 0.75rem;
				--shadow-sm: 0 1px 2px rgba(27, 57, 86, 0.05);
				--shadow-md: 0 4px 6px rgba(27, 57, 86, 0.1);
				--shadow-lg: 0 10px 25px rgba(27, 57, 86, 0.15);
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-family);
				color: var(--color-text);
				background: var(--color-bg);
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			a {
				color: inherit;
			}

			img {
				max-width: 100%;
				height: auto;
			}
		</style>
	</head>
	<body>
		<FloatingFollowBar />
		<Header />
		<main>
			<section class="portfolio-hero-simple">
				<div class="portfolio-hero-simple-container">
					<h1 class="portfolio-hero-simple-heading">My Portfolio</h1>
					<p class="portfolio-hero-simple-subheadline">
						A curated selection of production mobile applications I've developed and maintained — spanning consumer marketplaces, e-commerce, education, health, entertainment, internal tools, and niche utilities.
					</p>
				</div>
			</section>
			<section class="portfolio-projects-section" id="projects">
				<div class="portfolio-projects-container">
					<h2 class="portfolio-projects-heading">Projects</h2>
					<PortfolioGridWithFilter />
				</div>
			</section>
			<PortfolioCTA />
			<SkillsPills />
		</main>
		<Footer />
		<ScrollToBottom />
	</body>
</html>

<style>
	.portfolio-hero-simple {
		padding: 4rem 1.5rem 3rem;
		background: var(--color-bg);
		text-align: center;
	}

	.portfolio-hero-simple-container {
		max-width: 720px;
		margin: 0 auto;
	}

	.portfolio-hero-simple-heading {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 800;
		color: var(--color-navy);
		margin: 0 0 1rem 0;
		letter-spacing: -0.02em;
		line-height: 1.1;
	}

	.portfolio-hero-simple-subheadline {
		font-size: clamp(1rem, 2vw, 1.15rem);
		color: var(--color-text-light);
		line-height: 1.6;
		margin: 0;
	}

	.portfolio-projects-section {
		padding: 2rem 1.5rem 4rem;
		background: var(--color-bg);
	}

	.portfolio-projects-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	.portfolio-projects-heading {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 700;
		color: var(--color-navy);
		margin: 0 0 1.5rem 0;
		text-align: center;
	}
</style>
