---
import type { PortfolioProject } from "../../data/portfolio";
import { getProjectImages } from "../../data/portfolio";

interface Props {
	project: PortfolioProject;
}
const { project } = Astro.props;
const imageUrls = getProjectImages(project);
const heroImage = imageUrls[0] ?? null;
const snippet = project.roleSnippet ?? project.achievementSnippet ?? "";
---

<a
	href={`/portfolio/${project.id}`}
	class="portfolio-card-wrap"
	data-project-type={project.type}
	data-project-id={project.id}
>
	<article class="portfolio-card">
		<div class="portfolio-card-media">
			{heroImage ? (
				<img
					src={heroImage}
					alt=""
					class="portfolio-card-hero-img"
					loading="lazy"
					decoding="async"
				/>
			) : (
				<div class="portfolio-card-hero-placeholder" aria-hidden="true" />
			)}
			<div class="portfolio-card-badge">
				<span class="portfolio-card-badge-name">{project.name}</span>
			</div>
		</div>
		<div class="portfolio-card-body">
			<p class="portfolio-card-description">{project.description}</p>
			<div class="portfolio-card-tech" role="list">
				{project.tech.slice(0, 5).map((t) => (
					<span class="tech-pill" role="listitem">{t}</span>
				))}
			</div>
			{snippet && (
				<p class="portfolio-card-snippet" data-snippet>{snippet}</p>
			)}
			<div class="portfolio-card-actions">
				{project.url && project.url !== "#" && (
					<a
						href={project.url}
						class="portfolio-card-link"
						target="_blank"
						rel="noopener noreferrer"
					>
						{project.linkLabel}
					</a>
				)}
				{project.urlSecondary && project.urlSecondary !== "#" && (
					<a
						href={project.urlSecondary}
						class="portfolio-card-link secondary"
						target="_blank"
						rel="noopener noreferrer"
					>
						{project.linkLabelSecondary ?? "Website"}
					</a>
				)}
				{(!project.url || project.url === "#") && (
					<span class="portfolio-card-muted">{project.linkLabel}</span>
				)}
				<span class="portfolio-card-detail-link">View details →</span>
			</div>
			{project.note && (
				<p class="portfolio-card-note">{project.note}</p>
			)}
		</div>
	</article>
</a>

<style>
	.portfolio-card-wrap {
		display: block;
		text-decoration: none;
		color: inherit;
		height: 100%;
	}

	.portfolio-card {
		background: #fff;
		border-radius: 14px;
		overflow: hidden;
		box-shadow: 0 2px 12px rgba(27, 57, 86, 0.06);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.portfolio-card-wrap:hover .portfolio-card {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(27, 57, 86, 0.12);
	}

	.portfolio-card-media {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: linear-gradient(145deg, var(--color-navy, #1b3956) 0%, #2a4a6e 100%);
		flex-shrink: 0;
	}

	.portfolio-card-hero-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.portfolio-card-wrap:hover .portfolio-card-hero-img {
		transform: scale(1.05);
	}

	.portfolio-card-hero-placeholder {
		position: absolute;
		inset: 0;
		background: linear-gradient(145deg, var(--color-teal, #2f9983) 0%, #247a68 100%);
	}

	.portfolio-card-badge {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		width: min(100px, 45%);
		aspect-ratio: 1;
		min-width: 72px;
		min-height: 72px;
		background: rgba(255, 255, 255, 0.95);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
		padding: 0.5rem;
	}

	.portfolio-card-badge-name {
		font-size: clamp(0.65rem, 1.8vw, 0.8rem);
		font-weight: 700;
		color: var(--color-navy, #1b3956);
		text-align: center;
		line-height: 1.15;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.portfolio-card-body {
		padding: 1rem 1.25rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		flex: 1;
	}

	.portfolio-card-description {
		font-size: 0.85rem;
		color: var(--color-text-light, #6b7280);
		line-height: 1.5;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.portfolio-card-tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.portfolio-card-tech .tech-pill {
		font-size: 0.65rem;
		font-weight: 600;
		color: var(--color-teal, #2f9983);
		background: rgba(47, 153, 131, 0.1);
		padding: 0.2rem 0.45rem;
		border-radius: 4px;
	}

	.portfolio-card-snippet {
		font-size: 0.8rem;
		color: var(--color-navy, #1b3956);
		opacity: 0.85;
		line-height: 1.4;
		margin: 0;
		padding-top: 0.25rem;
		border-top: 1px solid rgba(27, 57, 86, 0.08);
	}

	.portfolio-card-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}

	.portfolio-card-link {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-teal, #2f9983);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.portfolio-card-link:hover {
		color: var(--color-navy, #1b3956);
	}

	.portfolio-card-link.secondary {
		color: var(--color-text-light, #6b7280);
	}

	.portfolio-card-muted {
		font-size: 0.8rem;
		color: var(--color-text-light, #6b7280);
	}

	.portfolio-card-detail-link {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-teal, #2f9983);
		margin-left: auto;
	}

	.portfolio-card-note {
		font-size: 0.75rem;
		color: var(--color-text-light, #6b7280);
		font-style: italic;
		margin: 0;
	}
</style>
