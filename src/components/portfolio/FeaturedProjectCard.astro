---
import type { PortfolioProject } from "../../data/portfolio";
import { getProjectImages } from "../../data/portfolio";

interface Props {
	project: PortfolioProject;
}
const { project } = Astro.props;
const imageUrls = getProjectImages(project);
const heroImage = imageUrls[0] ?? null;
---

<article class="featured-card">
	<div class="featured-card-media">
		{heroImage ? (
			<img
				src={heroImage}
				alt=""
				class="featured-card-hero-img"
				loading="lazy"
				decoding="async"
			/>
		) : (
			<div class="featured-card-hero-placeholder" aria-hidden="true" />
		)}
		<div class="featured-card-badge">
			<span class="featured-card-badge-name">{project.name}</span>
		</div>
	</div>
	<div class="featured-card-body">
		<h3 class="featured-card-title">{project.name}</h3>
		<p class="featured-card-pitch">{project.pitch}</p>
		<div class="featured-card-tech" role="list" aria-label="Tech stack">
			{project.tech.slice(0, 5).map((t) => (
				<span class="tech-pill" role="listitem">{t}</span>
			))}
		</div>
		<a
			href={project.url}
			class="featured-card-cta"
			target={project.url.startsWith("http") ? "_blank" : undefined}
			rel={project.url.startsWith("http") ? "noopener noreferrer" : undefined}
		>
			{project.linkLabel}
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<line x1="5" y1="12" x2="19" y2="12"></line>
				<polyline points="12 5 19 12 12 19"></polyline>
			</svg>
		</a>
	</div>
</article>

<style>
	.featured-card {
		background: #fff;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 4px 20px rgba(27, 57, 86, 0.08);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		display: flex;
		flex-direction: column;
	}

	.featured-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 12px 32px rgba(27, 57, 86, 0.15);
	}

	.featured-card-media {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: linear-gradient(145deg, var(--color-navy, #1b3956) 0%, #2a4a6e 100%);
		flex-shrink: 0;
	}

	.featured-card-hero-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.featured-card:hover .featured-card-hero-img {
		transform: scale(1.05);
	}

	.featured-card-hero-placeholder {
		position: absolute;
		inset: 0;
		background: linear-gradient(145deg, var(--color-teal, #2f9983) 0%, #247a68 100%);
	}

	.featured-card-badge {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		width: min(110px, 42%);
		aspect-ratio: 1;
		min-width: 80px;
		min-height: 80px;
		background: rgba(255, 255, 255, 0.95);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
		padding: 0.5rem;
	}

	.featured-card-badge-name {
		font-size: clamp(0.7rem, 1.8vw, 0.85rem);
		font-weight: 700;
		color: var(--color-navy, #1b3956);
		text-align: center;
		line-height: 1.15;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.featured-card-body {
		padding: 1.25rem 1.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.featured-card-title {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--color-navy, #1b3956);
		margin: 0;
		line-height: 1.2;
	}

	.featured-card-pitch {
		font-size: 0.9rem;
		color: var(--color-text-light, #6b7280);
		line-height: 1.5;
		margin: 0;
	}

	.featured-card-tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.tech-pill {
		font-size: 0.7rem;
		font-weight: 600;
		color: var(--color-teal, #2f9983);
		background: rgba(47, 153, 131, 0.12);
		padding: 0.25rem 0.5rem;
		border-radius: 6px;
	}

	.featured-card-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--color-teal, #2f9983);
		text-decoration: none;
		margin-top: 0.25rem;
		transition: color 0.2s ease, gap 0.2s ease;
	}

	.featured-card-cta:hover {
		color: var(--color-navy, #1b3956);
		gap: 0.6rem;
	}

	.featured-card-cta[href="#"] {
		pointer-events: none;
		opacity: 0.8;
	}
</style>
