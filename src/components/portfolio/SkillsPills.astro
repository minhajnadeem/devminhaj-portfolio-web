---
import type { SkillCategory } from "../../data/skills";
import { skillsIntro, skillCategories } from "../../data/skills";

interface Props {
	intro?: string;
	categories?: SkillCategory[];
}
const { intro = skillsIntro, categories = skillCategories } = Astro.props;
---

<section class="skills-section" id="skills">
	<div class="skills-container">
		<h2 class="skills-heading">Skills at a glance</h2>
		<p class="skills-intro">{intro}</p>
		<div class="skills-grid">
			{categories.map((cat) => (
				<div class="skills-category">
					<h3 class="skills-category-name">{cat.category}</h3>
					<div class="skills-pills" role="list">
						{cat.items.map((item) => (
							<span class="skill-pill" role="listitem">{item}</span>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.skills-section {
		padding: 4rem 1.5rem;
		background: #fff;
	}

	.skills-container {
		max-width: 1100px;
		margin: 0 auto;
	}

	.skills-heading {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 700;
		color: var(--color-navy, #1b3956);
		margin: 0 0 0.5rem 0;
		text-align: center;
	}

	.skills-intro {
		font-size: 1rem;
		color: var(--color-text-light, #6b7280);
		text-align: center;
		max-width: 560px;
		margin: 0 auto 2.5rem;
		line-height: 1.6;
	}

	.skills-grid {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.skills-category {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.skills-category-name {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--color-navy, #1b3956);
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.skills-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.skill-pill {
		font-size: 0.85rem;
		color: var(--color-navy, #1b3956);
		background: rgba(27, 57, 86, 0.06);
		border: 1px solid rgba(27, 57, 86, 0.12);
		padding: 0.4rem 0.75rem;
		border-radius: 999px;
		transition: background 0.2s ease, border-color 0.2s ease;
	}

	.skill-pill:hover {
		background: rgba(47, 153, 131, 0.1);
		border-color: rgba(47, 153, 131, 0.3);
	}
</style>
