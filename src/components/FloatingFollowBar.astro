---
// "Follow Me" scrolls to #connect: footer (Let's Connect) on Home/Portfolio, social section on Contact
---

<a href="#connect" class="follow-bar" aria-label="Scroll to follow and connect links">
	<span class="follow-bar-label">Follow Me</span>
</a>

<style>
	.follow-bar {
		position: fixed;
		top: 50%;
		right: 0;
		transform: translateY(-50%);
		width: 48px;
		padding: 12px 8px;
		padding-right: max(8px, env(safe-area-inset-right));
		background: #2f9983;
		backdrop-filter: blur(8px);
		border-radius: 12px 0 0 12px;
		box-shadow: -2px 0 12px rgba(47, 153, 131, 0.35);
		z-index: 900;
		display: flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		color: #f7f0f0;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.follow-bar:hover {
		background: #257a68;
		color: #f7f0f0;
	}

	.follow-bar-label {
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		writing-mode: vertical-rl;
		text-orientation: mixed;
		transform: rotate(180deg);
		line-height: 1.3;
	}

	@media (min-width: 769px) {
		.follow-bar {
			width: 52px;
			padding: 16px 10px;
			padding-right: max(10px, env(safe-area-inset-right));
		}

		.follow-bar-label {
			font-size: 0.75rem;
		}
	}
</style>
